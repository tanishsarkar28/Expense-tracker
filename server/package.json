{
  "name": "expense-tracker-server",
  "version": "1.0.0",
  "description": "Backend API for Expense Tracker",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "npx prisma migrate deploy && node index.js",
